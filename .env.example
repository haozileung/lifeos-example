# LifeOS Environment Variables
# Copy this file to .env and fill in your values

# --- Teams Notification (Power Automate Webhook) ---
# Used by: teams-notify skill, weekly-report skill
# Get from: Power Automate → "When a Teams webhook request is received" trigger
TEAMS_WEBHOOK_URL=https://your-tenant.environment.api.powerplatform.com/powerautomate/automations/direct/workflows/YOUR-WORKFLOW-ID/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=YOUR-SIGNATURE

# --- Email Processor (IMAP) ---
# Used by: email-processor skill
IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=your@email.com
IMAP_PASSWORD=your-app-password
